{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "useDefineForClassFields": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"],
    "lib": ["ES2022", "DOM"],
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "com.bknadir.streamboard.sdPlugin/bin"]
}